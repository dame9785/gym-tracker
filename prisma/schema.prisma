generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  firstName        String?           @db.VarChar(50)
  lastName         String?           @db.VarChar(50)
  username         String            @unique @db.VarChar(50)
  email            String            @unique @db.VarChar(100)
  phoneNumber      String?           @db.VarChar(20)
  passwordHash     String
  bodyWeight       Decimal?          @db.Decimal(5, 2)
  goalWeight       Decimal?          @db.Decimal(5, 2)
  bodyLength       Decimal?          @db.Decimal(5, 2)
  gender           Gender?
  birthDate        DateTime?         @db.Date
  goalDate         DateTime?         @db.Date
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  goalTypeId       Int?
  goalType         GoalType?         @relation(fields: [goalTypeId], references: [id])
  goal             Goal?
  workout          Workout[]
  workoutSchedules WorkoutSchedule[]
}

model GoalType {
  id    Int    @id @default(autoincrement())
  title String @unique
  users User[]
}

model Goal {
  id       Int  @id @default(autoincrement())
  userId   Int  @unique
  user     User @relation(fields: [userId], references: [id])
  calories Int?
  protein  Int?
  carbs    Int?
  fat      Int?
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Workout {
  id          Int               @id @default(autoincrement())
  userId      Int
  user        User              @relation(fields: [userId], references: [id])
  name        String            @db.VarChar(100)
  description String?           @db.VarChar(500)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  exercises   WorkoutExercise[]
  schedules   WorkoutSchedule[]
}

model WorkoutExercise {
  id          Int      @id @default(autoincrement())
  workoutId   Int
  workout     Workout  @relation(fields: [workoutId], references: [id])
  exerciseId  Int
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  sets        Int
  reps        Int
  weight      Float?
  restSeconds Int?
  order       Int
  note        String?  @db.VarChar(500)
}

model Exercise {
  id          Int               @id @default(autoincrement())
  name        String
  muscleGroup String
  equipment   String?           @db.VarChar(50)
  workouts    WorkoutExercise[]
}

model WorkoutSchedule {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  workoutId Int
  workout   Workout  @relation(fields: [workoutId], references: [id])
  date      DateTime
  createdAt DateTime @default(now())
}
